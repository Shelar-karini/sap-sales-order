    "generate": "node scripts/generate-schema.js",
    "deploy:hana": "cds deploy --to hana"
  },
  "dependencies": {
    "@sap/cds": "^9.0.0",
    "@sap/hana-client": "^2.0.0",
    "@cap-js/hana": "^1.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.0.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      }
    }
  }
}
